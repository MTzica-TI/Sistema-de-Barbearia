generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

enum Plano {
  Avulso
  Mensal
  Premium
}

enum StatusAgendamento {
  Confirmado
  Cancelado
}

enum PagamentoStatus {
  Pendente
  Confirmado
}

enum StatusAssinatura {
  Ativa
  Cancelada
}

model Agendamento {
  id              String            @id
  clienteNome     String
  clienteTelefone String
  plano           Plano
  servicoId       String
  servicoNome     String
  barbeiroId      String
  barbeiroNome    String
  data            String
  horario         String
  status          StatusAgendamento @default(Confirmado)
  pagamentoStatus PagamentoStatus   @default(Pendente)
  criadoEm        DateTime          @default(now())

  @@index([data, barbeiroId, status])
}

model Barbeiro {
  id           String  @id
  nome         String
  especialidade String
  fotoUrl      String
  senha        String  @default("barber123")
  ativo        Boolean @default(true)
}

model Servico {
  id               String  @id
  nome             String  @unique
  preco            Float
  duracaoMinutos   Int
  criadoEm         DateTime @default(now())
}

model PlanoAssinatura {
  id             String   @id
  tipo           Plano
  nome           String
  preco          String
  ciclo          String   @default("/mes")
  destaque       Boolean  @default(false)
  beneficiosTexto String
  ordem          Int      @default(0)
  ativo          Boolean  @default(true)
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt
}

model FormaPagamentoAssinatura {
  id           String   @id
  descricao    String
  ordem        Int      @default(0)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model AssinaturaCliente {
  id               String           @id
  clienteNome      String
  clienteTelefone  String           @unique
  plano            Plano
  status           StatusAssinatura @default(Ativa)
  iniciadoEm       DateTime         @default(now())
  proximaCobrancaEm DateTime?
  canceladoEm      DateTime?
  atualizadoEm     DateTime         @updatedAt
}
